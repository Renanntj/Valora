#arquivo .env.example

# Gere com: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=SUBSTITUA_POR_UMA_CHAVE_ALEATORIA_DE_64_BYTES_HEX

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Exemplos de DATABASE_URL:
# PostgreSQL: postgresql://user:password@localhost:5432/saas_db
# SQLite (dev): sqlite:///./saas_dev.db
DATABASE_URL=postgresql://user:password@localhost:5432/saas_db

ENVIRONMENT=development  # development | production